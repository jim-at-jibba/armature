#!/usr/bin/env bash
set -euo pipefail

TEMPLATE="armature:v1"
CONTAINER_PREFIX="armature"

# --- Help ---

show_help() {
  cat <<'HELP'
Armature — the internal skeleton that gives a robot its structure.
Armature gives Claude Code a safe, isolated frame to operate in.

Usage:
  armature [run] <branch|path> [prompt] [flags]
  armature attach [branch]
  armature ls
  armature stop [branch]
  armature rm <branch>

Commands:
  run       Create a worktree (if needed) and launch a container (default)
  attach    Attach to a running container (infers from cwd if no branch given)
  ls        List running Armature containers
  stop      Stop a container (infers from cwd if no branch given)
  rm        Stop and remove a container

Flags:
  -d, --detach        Launch container in the background
  --prompt <file>     Pass a prompt file to Claude
  -h, --help          Show this help message
HELP
}

# --- Helpers ---

die() {
  echo "armature: $1" >&2
  exit 1
}

require_git() {
  git rev-parse --git-dir > /dev/null 2>&1 \
    || die "not inside a git repository"
}

require_docker() {
  docker info > /dev/null 2>&1 \
    || die "docker is not available — is Docker running?"
}

require_template() {
  docker image inspect "$TEMPLATE" > /dev/null 2>&1 \
    || die "template image $TEMPLATE not found — run: docker build -t $TEMPLATE ."
}

repo_name() {
  basename "$(git rev-parse --show-toplevel)"
}

sanitise() {
  echo "$1" | tr '/' '-' | tr -c '[:alnum:]-_.' '-' | sed 's/^-//;s/-$//'
}

container_name() {
  echo "${CONTAINER_PREFIX}-$(sanitise "$1")"
}

container_running() {
  docker ps --filter "name=^${1}$" --format '{{.Names}}' 2>/dev/null | grep -q "^${1}$"
}

branch_from_cwd() {
  local branch
  branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) \
    || die "cannot detect branch from current directory"
  echo "$branch"
}

# --- Subcommands ---

cmd_run() {
  local target=""
  local prompt=""
  local prompt_file=""
  local detach=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -d|--detach)   detach=true; shift ;;
      --prompt)
        [[ -n "${2:-}" ]] || die "--prompt requires a file argument"
        prompt_file="$2"
        [[ -f "$prompt_file" ]] || die "prompt file not found: $prompt_file"
        prompt_file="$(cd "$(dirname "$prompt_file")" && pwd)/$(basename "$prompt_file")"
        shift 2
        ;;
      -h|--help)     show_help; exit 0 ;;
      *)
        if [[ -z "$target" ]]; then
          target="$1"
        elif [[ -z "$prompt" ]]; then
          prompt="$1"
        else
          die "unexpected argument: $1"
        fi
        shift
        ;;
    esac
  done

  [[ -n "$target" ]] || die "usage: armature run <branch|path> [prompt] [flags]"

  # Resolve worktree
  local worktree_path branch

  if [[ -d "$target" ]]; then
    worktree_path="$(cd "$target" && pwd)"
    branch=$(cd "$worktree_path" && git rev-parse --abbrev-ref HEAD) \
      || die "$target is not a git directory"
  else
    require_git
    branch="$target"
    local repo
    repo=$(repo_name)
    worktree_path="$(cd "$(git rev-parse --show-toplevel)/.." && pwd)/${repo}-$(sanitise "$branch")"

    if [[ -d "$worktree_path" ]]; then
      (cd "$worktree_path" && git rev-parse --git-dir > /dev/null 2>&1) \
        || die "$worktree_path exists but is not a git worktree"
      echo "Using existing worktree at $worktree_path"
    else
      if ! git rev-parse --verify "$branch" > /dev/null 2>&1; then
        echo "Creating branch $branch from HEAD"
        git branch "$branch"
      fi
      echo "Creating worktree at $worktree_path"
      git worktree add "$worktree_path" "$branch"
    fi
  fi

  require_docker
  require_template

  local name
  name=$(container_name "$branch")

  # If container already exists, attach instead
  if container_running "$name"; then
    if [[ -n "$prompt" || -n "$prompt_file" ]]; then
      echo "Warning: container $name is already running — ignoring prompt, attaching" >&2
    else
      echo "Container $name is already running — attaching"
    fi
    exec docker exec -it "$name" claude --dangerously-skip-permissions
  fi

  # Remove stopped container with same name if it exists
  docker rm "$name" 2>/dev/null || true

  # Build claude args
  local -a claude_args=(--dangerously-skip-permissions)

  if [[ -n "$prompt" ]]; then
    claude_args+=(-p "$prompt")
  elif [[ -n "$prompt_file" ]]; then
    claude_args+=(--prompt-file "/workspace/.armature-prompt")
  fi

  # Build docker run command
  local -a cmd=(docker run
    --name "$name"
    -v "$worktree_path:/workspace"
    -v "${HOME}/.claude:/home/node/.claude"
  )

  # Resolve symlinks in .claude (hooks, skills, commands may point outside ~/.claude)
  for link in "${HOME}/.claude/hooks" "${HOME}/.claude/skills" "${HOME}/.claude/commands"; do
    if [[ -L "$link" ]]; then
      local target
      target=$(readlink "$link")
      cmd+=(-v "$target:$target:ro")
    fi
  done

  # Copy .claude.json to a temp file and mount that (Claude needs write access
  # but we don't want it writing back to the host copy)
  if [[ -f "${HOME}/.claude.json" ]]; then
    local tmp_claude_json
    tmp_claude_json=$(mktemp)
    cp "${HOME}/.claude.json" "$tmp_claude_json"
    cmd+=(-v "$tmp_claude_json:/home/node/.claude.json")
  fi

  # Pass through OAuth token if set
  if [[ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]]; then
    cmd+=(-e "CLAUDE_CODE_OAUTH_TOKEN=${CLAUDE_CODE_OAUTH_TOKEN}")
  fi

  # Mount prompt file into container if provided
  if [[ -n "$prompt_file" ]]; then
    cmd+=(-v "$prompt_file:/workspace/.armature-prompt:ro")
  fi

  echo "Launching container $name for $worktree_path"

  if [[ "$detach" == true ]]; then
    cmd+=(-d)
    cmd+=("$TEMPLATE" claude "${claude_args[@]}")
    "${cmd[@]}"
    echo "Container $name launched in background"
  else
    cmd+=(-it)
    cmd+=("$TEMPLATE" claude "${claude_args[@]}")
    exec "${cmd[@]}"
  fi
}

cmd_attach() {
  require_docker

  local branch

  if [[ $# -gt 0 ]]; then
    branch="$1"
  else
    require_git
    branch=$(branch_from_cwd)
  fi

  local name
  name=$(container_name "$branch")

  container_running "$name" || die "no running container named $name"

  echo "Attaching to container $name"
  exec docker exec -it "$name" claude --dangerously-skip-permissions
}

cmd_ls() {
  require_docker
  echo "Running Armature containers:"
  docker ps --filter "name=${CONTAINER_PREFIX}-" --format "  {{.Names}}\t{{.Status}}" 2>/dev/null || echo "  (none)"
}

cmd_stop() {
  require_docker

  local branch

  if [[ $# -gt 0 ]]; then
    branch="$1"
  else
    require_git
    branch=$(branch_from_cwd)
  fi

  local name
  name=$(container_name "$branch")

  echo "Stopping container $name"
  docker stop "$name"
}

cmd_rm() {
  require_docker

  [[ $# -gt 0 ]] || die "usage: armature rm <branch>"

  local name
  name=$(container_name "$1")

  echo "Stopping and removing container $name"
  docker stop "$name" 2>/dev/null || true
  docker rm "$name"
}

# --- Main dispatcher ---

main() {
  case "${1:-}" in
    -h|--help) show_help; exit 0 ;;
    run)       shift; cmd_run "$@" ;;
    attach)    shift; cmd_attach "$@" ;;
    ls)        cmd_ls ;;
    stop)      shift; cmd_stop "$@" ;;
    rm)        shift; cmd_rm "$@" ;;
    "")        show_help; exit 0 ;;
    *)         cmd_run "$@" ;;
  esac
}

main "$@"
