#!/usr/bin/env bash
set -euo pipefail

DEFAULT_IMAGE="armature:v1"
CONTAINER_PREFIX="armature"

# --- Gum detection ---

HAS_GUM=false
command -v gum &>/dev/null && HAS_GUM=true

# --- Fancy output helpers (gum with plain fallback) ---

fancy_header() {
  if [[ "$HAS_GUM" == true ]]; then
    gum style --border rounded --foreground 212 --border-foreground 212 --padding "0 1" "$1"
  else
    echo "=== $1 ==="
  fi
}

fancy_log() {
  if [[ "$HAS_GUM" == true ]]; then
    gum style --foreground 212 "  $1"
  else
    echo "$1"
  fi
}

fancy_warn() {
  if [[ "$HAS_GUM" == true ]]; then
    gum style --foreground 214 "  ⚠ $1" >&2
  else
    echo "Warning: $1" >&2
  fi
}

fancy_error() {
  if [[ "$HAS_GUM" == true ]]; then
    gum style --foreground 196 "  ✗ $1" >&2
  else
    echo "armature: $1" >&2
  fi
}

fancy_spin() {
  local msg="$1"
  shift
  if [[ "$HAS_GUM" == true ]]; then
    gum spin --spinner dot --title "$msg" -- "$@"
  else
    echo "$msg"
    "$@"
  fi
}

fancy_table() {
  if [[ "$HAS_GUM" == true ]]; then
    gum format --type template
  else
    column -t
  fi
}

# Resolve image: .armature.json > ARMATURE_IMAGE env var > default
resolve_image() {
  # Check for .armature.json in the worktree or current directory
  local config_file="${1:-.}/.armature.json"
  if [[ -f "$config_file" ]]; then
    local img
    img=$(jq -r '.image // empty' "$config_file" 2>/dev/null)
    if [[ -n "$img" ]]; then
      echo "$img"
      return
    fi
  fi

  # Fall back to env var, then default
  echo "${ARMATURE_IMAGE:-$DEFAULT_IMAGE}"
}

# Resolve Claude token: global config > env var
# Warns if token found in project-level config (risks being committed)
resolve_claude_token() {
  local worktree_path="$1"

  # Warn if token present in project config
  if [[ -f "${worktree_path}/.armature.json" ]]; then
    local project_token
    project_token=$(jq -r '.claude_token // empty' "${worktree_path}/.armature.json" 2>/dev/null)
    if [[ -n "$project_token" ]]; then
      fancy_warn "token in project config is risky — move to ~/.armature.json"
    fi
  fi

  # Global config wins
  if [[ -f "${HOME}/.armature.json" ]]; then
    local global_token
    global_token=$(jq -r '.claude_token // empty' "${HOME}/.armature.json" 2>/dev/null)
    if [[ -n "$global_token" ]]; then
      echo "$global_token"
      return
    fi
  fi

  # Fall back to env var
  echo "${CLAUDE_CODE_OAUTH_TOKEN:-}"
}

# Load hooks array from a config file for a given lifecycle point
# Usage: load_hooks <config_file> <lifecycle_point>
# Outputs one hook command per line
load_hooks() {
  local config_file="$1"
  local lifecycle="$2"

  if [[ -f "$config_file" ]]; then
    jq -r --arg lc "$lifecycle" '.hooks[$lc] // [] | if type == "array" then .[] else . end' "$config_file" 2>/dev/null
  fi
}

# Merge hooks from global and project configs (global first, then project)
# Usage: merge_hooks <worktree_path> <lifecycle_point>
# Outputs one hook command per line
merge_hooks() {
  local worktree_path="$1"
  local lifecycle="$2"

  load_hooks "${HOME}/.armature.json" "$lifecycle"
  load_hooks "${worktree_path}/.armature.json" "$lifecycle"
}

# Read hook timeout from a config file (default 30)
hook_timeout() {
  local config_file="$1"
  if [[ -f "$config_file" ]]; then
    jq -r '.hooks.timeout // empty' "$config_file" 2>/dev/null
  fi
}

# Resolve the hook timeout: project config > global config > 30s default
resolve_hook_timeout() {
  local worktree_path="$1"
  local timeout

  timeout=$(hook_timeout "${worktree_path}/.armature.json")
  if [[ -n "$timeout" ]]; then
    echo "$timeout"
    return
  fi

  timeout=$(hook_timeout "${HOME}/.armature.json")
  if [[ -n "$timeout" ]]; then
    echo "$timeout"
    return
  fi

  echo "30"
}

# Run hooks for a given lifecycle point
# Usage: run_hooks <worktree_path> <lifecycle_point>
# Environment variables are set before calling this function
run_hooks() {
  local worktree_path="$1"
  local lifecycle="$2"
  local timeout
  timeout=$(resolve_hook_timeout "$worktree_path")

  local hooks
  hooks=$(merge_hooks "$worktree_path" "$lifecycle")

  if [[ -z "$hooks" ]]; then
    return 0
  fi

  local timeout_cmd=""
  if command -v gtimeout &>/dev/null; then
    timeout_cmd="gtimeout $timeout"
  elif command -v timeout &>/dev/null; then
    timeout_cmd="timeout $timeout"
  fi

  fancy_log "Running $lifecycle hooks..."

  local IFS=$'\n'
  for hook in $hooks; do
    [[ -n "$hook" ]] || continue
    fancy_log "  hook: $hook"
    if [[ -n "$timeout_cmd" ]]; then
      if ! $timeout_cmd bash -c "$hook" </dev/null; then
        fancy_warn "$lifecycle hook failed: $hook"
      fi
    else
      if ! bash -c "$hook" </dev/null; then
        fancy_warn "$lifecycle hook failed: $hook"
      fi
    fi
  done
}

# --- Help ---

show_help() {
  fancy_header "Armature"
  cat <<'HELP'
The internal skeleton that gives a robot its structure.
Armature gives Claude Code a safe, isolated frame to operate in.

Usage:
  armature [run] [branch|path] [prompt] [flags]
  armature attach [branch]
  armature ls
  armature stop [branch]
  armature rm <branch>

Commands:
  run       Create a worktree (if needed) and launch a container (default)
            If no branch or path is given, the current directory is used.
  attach    Attach to a running container (infers from cwd if no branch given)
  ls        List running Armature containers
  stop      Stop a container (infers from cwd if no branch given)
  rm        Stop and remove a container

Flags:
  -d, --detach        Launch container in the background
  --prompt <file>     Pass a prompt file to Claude
  -h, --help          Show this help message

Hooks:
  Define lifecycle hooks in ~/.armature.json or .armature.json:
  {"hooks": {"pre-run": [...], "post-run": [...]}}
  See README for details.
HELP
}

# --- Helpers ---

die() {
  fancy_error "$1"
  exit 1
}

require_git() {
  git rev-parse --git-dir > /dev/null 2>&1 \
    || die "not inside a git repository"
}

require_docker() {
  docker info > /dev/null 2>&1 \
    || die "docker is not available — is Docker running?"
}

require_image() {
  docker image inspect "$1" > /dev/null 2>&1 \
    || die "image $1 not found — build it with: docker build -t $1 ."
}

repo_name() {
  basename "$(git rev-parse --show-toplevel)"
}

sanitise() {
  echo "$1" | tr '/' '-' | tr -c '[:alnum:]-_.' '-' | sed 's/^-//;s/-$//'
}

container_name() {
  echo "${CONTAINER_PREFIX}-$(sanitise "$1")"
}

container_running() {
  docker ps --filter "name=^${1}$" --format '{{.Names}}' 2>/dev/null | grep -q "^${1}$"
}

branch_from_cwd() {
  local branch
  branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) \
    || die "cannot detect branch from current directory"
  echo "$branch"
}

# --- Subcommands ---

cmd_run() {
  local target=""
  local prompt=""
  local prompt_file=""
  local detach=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -d|--detach)   detach=true; shift ;;
      --prompt)
        [[ -n "${2:-}" ]] || die "--prompt requires a file argument"
        prompt_file="$2"
        [[ -f "$prompt_file" ]] || die "prompt file not found: $prompt_file"
        prompt_file="$(cd "$(dirname "$prompt_file")" && pwd)/$(basename "$prompt_file")"
        shift 2
        ;;
      -h|--help)     show_help; exit 0 ;;
      *)
        if [[ -z "$target" ]]; then
          target="$1"
        elif [[ -z "$prompt" ]]; then
          prompt="$1"
        else
          die "unexpected argument: $1"
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$target" ]]; then
    require_git
    target="."
  fi

  # Resolve worktree
  local worktree_path branch

  if [[ -d "$target" ]]; then
    worktree_path="$(cd "$target" && pwd)"
    branch=$(cd "$worktree_path" && git rev-parse --abbrev-ref HEAD) \
      || die "$target is not a git directory"
  else
    require_git
    branch="$target"
    local repo
    repo=$(repo_name)
    worktree_path="$(cd "$(git rev-parse --show-toplevel)/.." && pwd)/${repo}-$(sanitise "$branch")"

    if [[ -d "$worktree_path" ]]; then
      (cd "$worktree_path" && git rev-parse --git-dir > /dev/null 2>&1) \
        || die "$worktree_path exists but is not a git worktree"
      fancy_log "Using existing worktree at $worktree_path"
    else
      if ! git rev-parse --verify "$branch" > /dev/null 2>&1; then
        fancy_log "Creating branch $branch from HEAD"
        git branch "$branch"
      fi
      fancy_spin "Creating worktree at $worktree_path" git worktree add "$worktree_path" "$branch"
    fi
  fi

  require_docker

  local image
  image=$(resolve_image "$worktree_path")
  require_image "$image"

  local name
  name=$(container_name "$branch")

  # Export hook environment variables
  export ARMATURE_BRANCH="$branch"
  export ARMATURE_WORKTREE="$worktree_path"
  export ARMATURE_CONTAINER="$name"
  export ARMATURE_PROJECT="$(basename "$(cd "$worktree_path" && git rev-parse --show-toplevel)")"

  # Run pre-run hooks
  run_hooks "$worktree_path" "pre-run"

  # If container already exists, attach instead
  if container_running "$name"; then
    if [[ -n "$prompt" || -n "$prompt_file" ]]; then
      fancy_warn "container $name is already running — ignoring prompt, attaching"
    else
      fancy_log "Container $name is already running — attaching"
    fi
    local exit_code=0
    docker exec -it "$name" claude --dangerously-skip-permissions || exit_code=$?
    export ARMATURE_EXIT_CODE="$exit_code"
    run_hooks "$worktree_path" "post-run"
    return
  fi

  # Remove stopped container with same name if it exists
  docker rm "$name" 2>/dev/null || true

  # Build claude args
  local -a claude_args=(--dangerously-skip-permissions)

  if [[ -n "$prompt" ]]; then
    claude_args+=(-p "$prompt")
  elif [[ -n "$prompt_file" ]]; then
    claude_args+=(--prompt-file "/workspace/.armature-prompt")
  fi

  # Build docker run command
  # Mount the git common dir (bare repo or .git dir) so git commands work in the worktree
  local git_common_dir
  git_common_dir=$(cd "$worktree_path" && git rev-parse --git-common-dir 2>/dev/null | xargs realpath 2>/dev/null || true)

  local -a cmd=(docker run
    --name "$name"
    -e "ARMATURE=1"
    -v "$worktree_path:/workspace"
    -v "${HOME}/.claude:/home/node/.claude"
    -v "${HOME}/.claude:${HOME}/.claude"
  )

  if [[ -n "$git_common_dir" && "$git_common_dir" != "$worktree_path"* ]]; then
    cmd+=(-v "$git_common_dir:$git_common_dir:ro")
  fi

  # Resolve symlinks in .claude (hooks, skills, commands may point outside ~/.claude)
  for link in "${HOME}/.claude/hooks" "${HOME}/.claude/skills" "${HOME}/.claude/commands"; do
    if [[ -L "$link" ]]; then
      local target
      target=$(readlink -f "$link")
      cmd+=(-v "$target:$target:ro")
    fi
  done

  # Copy .claude.json to a temp file and mount that (Claude needs write access
  # but we don't want it writing back to the host copy)
  if [[ -f "${HOME}/.claude.json" ]]; then
    local tmp_claude_json
    tmp_claude_json=$(mktemp)
    cp "${HOME}/.claude.json" "$tmp_claude_json"
    cmd+=(-v "$tmp_claude_json:/home/node/.claude.json")
  fi

  # Pass through OAuth token if set
  if [[ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]]; then
    cmd+=(-e "CLAUDE_CODE_OAUTH_TOKEN=${CLAUDE_CODE_OAUTH_TOKEN}")
  fi

  # Mount prompt file into container if provided
  if [[ -n "$prompt_file" ]]; then
    cmd+=(-v "$prompt_file:/workspace/.armature-prompt:ro")
  fi

  fancy_log "Launching container $name for $worktree_path"

  if [[ "$detach" == true ]]; then
    cmd+=(-d)
    cmd+=("$image" claude "${claude_args[@]}")
    "${cmd[@]}"
    fancy_log "Container $name launched in background"
  else
    cmd+=(-it)
    cmd+=("$image" claude "${claude_args[@]}")
    local exit_code=0
    "${cmd[@]}" || exit_code=$?
    export ARMATURE_EXIT_CODE="$exit_code"
    run_hooks "$worktree_path" "post-run"
  fi
}

cmd_attach() {
  require_docker

  local branch

  if [[ $# -gt 0 ]]; then
    branch="$1"
  else
    require_git
    branch=$(branch_from_cwd)
  fi

  local name
  name=$(container_name "$branch")

  container_running "$name" || die "no running container named $name"

  # Resolve worktree path from container mounts
  local worktree_path
  worktree_path=$(docker inspect "$name" --format '{{range .Mounts}}{{if eq .Destination "/workspace"}}{{.Source}}{{end}}{{end}}')

  # Export hook environment variables
  export ARMATURE_BRANCH="$branch"
  export ARMATURE_WORKTREE="$worktree_path"
  export ARMATURE_CONTAINER="$name"
  export ARMATURE_PROJECT="$(basename "$(cd "$worktree_path" && git rev-parse --show-toplevel)")"

  # Run pre-run hooks
  run_hooks "$worktree_path" "pre-run"

  fancy_log "Attaching to container $name"
  local exit_code=0
  docker exec -it "$name" claude --dangerously-skip-permissions || exit_code=$?
  export ARMATURE_EXIT_CODE="$exit_code"
  run_hooks "$worktree_path" "post-run"
}

cmd_ls() {
  require_docker
  fancy_header "Running Containers"
  local output
  output=$(docker ps --filter "name=${CONTAINER_PREFIX}-" --format "{{.Names}}\t{{.Status}}" 2>/dev/null)
  if [[ -z "$output" ]]; then
    echo "  (none)"
  else
    echo "$output" | fancy_table
  fi
}

cmd_stop() {
  require_docker

  local branch

  if [[ $# -gt 0 ]]; then
    branch="$1"
  else
    require_git
    branch=$(branch_from_cwd)
  fi

  local name
  name=$(container_name "$branch")

  fancy_log "Stopping container $name"
  docker stop "$name"
}

cmd_rm() {
  require_docker

  [[ $# -gt 0 ]] || die "usage: armature rm <branch>"

  local name
  name=$(container_name "$1")

  fancy_log "Stopping and removing container $name"
  docker stop "$name" 2>/dev/null || true
  docker rm "$name"
}

# --- Main dispatcher ---

main() {
  case "${1:-}" in
    -h|--help) show_help; exit 0 ;;
    run)       shift; cmd_run "$@" ;;
    attach)    shift; cmd_attach "$@" ;;
    ls)        cmd_ls ;;
    stop)      shift; cmd_stop "$@" ;;
    rm)        shift; cmd_rm "$@" ;;
    "")        show_help; exit 0 ;;
    *)         cmd_run "$@" ;;
  esac
}

main "$@"
