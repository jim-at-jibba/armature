#!/usr/bin/env bash
set -euo pipefail

TEMPLATE="armature:v1"
SANDBOX_PREFIX="armature"

# --- Help ---

show_help() {
  cat <<'HELP'
Armature — the internal skeleton that gives a robot its structure.
Armature gives Claude Code a safe, isolated frame to operate in.

Usage:
  armature [run] <branch|path> [prompt] [flags]
  armature attach [branch]
  armature ls
  armature stop [branch]
  armature rm <branch>

Commands:
  run       Create a worktree (if needed) and launch a sandbox (default)
  attach    Attach to a running sandbox (infers from cwd if no branch given)
  ls        List running Armature sandboxes
  stop      Stop a sandbox (infers from cwd if no branch given)
  rm        Stop and remove a sandbox

Flags:
  -d, --detach        Launch sandbox in the background
  --prompt <file>     Pass a prompt file to Claude
  -h, --help          Show this help message
HELP
}

# --- Helpers ---

die() {
  echo "armature: $1" >&2
  exit 1
}

require_git() {
  git rev-parse --git-dir > /dev/null 2>&1 \
    || die "not inside a git repository"
}

require_docker_sandbox() {
  docker sandbox ls > /dev/null 2>&1 \
    || die "docker sandbox is not available — is Docker Desktop running?"
}

# Check the template image has been built
require_template() {
  docker image inspect "$TEMPLATE" > /dev/null 2>&1 \
    || die "template image $TEMPLATE not found — run: docker build -t $TEMPLATE ."
}

# Get the repo name (basename of the git toplevel)
repo_name() {
  basename "$(git rev-parse --show-toplevel)"
}

# Get the current branch name
current_branch() {
  git rev-parse --abbrev-ref HEAD
}

# Sanitise a branch name for use in paths and sandbox names
# Replaces slashes, spaces, and other invalid chars with hyphens
sanitise() {
  echo "$1" | tr '/' '-' | tr -c '[:alnum:]-_.' '-' | sed 's/^-//;s/-$//'
}

# Derive sandbox name from branch
sandbox_name() {
  echo "${SANDBOX_PREFIX}-$(sanitise "$1")"
}

# Check if a sandbox with the given name is running
sandbox_exists() {
  docker sandbox ls --json 2>/dev/null | jq -e ".[] | select(.name == \"$1\")" > /dev/null 2>&1
}

# Detect branch from current worktree directory
branch_from_cwd() {
  local branch
  branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) \
    || die "cannot detect branch from current directory"
  echo "$branch"
}

# --- Subcommand placeholders (filled in subsequent tasks) ---

cmd_run() {
  local target=""
  local prompt=""
  local prompt_file=""
  local detach=false

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -d|--detach)   detach=true; shift ;;
      --prompt)
        [[ -n "${2:-}" ]] || die "--prompt requires a file argument"
        prompt_file="$2"
        [[ -f "$prompt_file" ]] || die "prompt file not found: $prompt_file"
        shift 2
        ;;
      -h|--help)     show_help; exit 0 ;;
      *)
        if [[ -z "$target" ]]; then
          target="$1"
        elif [[ -z "$prompt" ]]; then
          prompt="$1"
        else
          die "unexpected argument: $1"
        fi
        shift
        ;;
    esac
  done

  [[ -n "$target" ]] || die "usage: armature run <branch|path> [prompt] [flags]"

  # Resolve worktree
  local worktree_path branch

  if [[ -d "$target" ]]; then
    # Existing directory — verify it's a git directory
    worktree_path="$(cd "$target" && pwd)"
    branch=$(cd "$worktree_path" && git rev-parse --abbrev-ref HEAD) \
      || die "$target is not a git directory"
  else
    # Treat as branch name — need to be inside a git repo
    require_git
    branch="$target"
    local repo
    repo=$(repo_name)
    worktree_path="$(git rev-parse --show-toplevel)/../${repo}-$(sanitise "$branch")"

    if [[ -d "$worktree_path" ]]; then
      # Verify it's actually a git directory
      (cd "$worktree_path" && git rev-parse --git-dir > /dev/null 2>&1) \
        || die "$worktree_path exists but is not a git worktree"
      echo "Using existing worktree at $worktree_path"
    else
      # Create branch if it doesn't exist
      if ! git rev-parse --verify "$branch" > /dev/null 2>&1; then
        echo "Creating branch $branch from HEAD"
        git branch "$branch"
      fi
      echo "Creating worktree at $worktree_path"
      git worktree add "$worktree_path" "$branch"
    fi
  fi

  require_docker_sandbox
  require_template

  local name
  name=$(sandbox_name "$branch")

  # If sandbox already exists, attach instead (warn if prompt would be discarded)
  if sandbox_exists "$name"; then
    if [[ -n "$prompt" || -n "$prompt_file" ]]; then
      echo "Warning: sandbox $name is already running — ignoring prompt, attaching to existing session" >&2
    else
      echo "Sandbox $name is already running — attaching"
    fi
    exec docker sandbox exec "$name" claude --dangerously-skip-permissions
  fi

  # Build docker sandbox run command
  local -a cmd=(docker sandbox run claude "$worktree_path" "${HOME}/.claude:ro"
    --name "$name"
    --template "$TEMPLATE"
    --)

  cmd+=(--dangerously-skip-permissions)

  if [[ -n "$prompt" ]]; then
    cmd+=(-p "$prompt")
  elif [[ -n "$prompt_file" ]]; then
    cmd+=(--prompt-file "$prompt_file")
  fi

  echo "Launching sandbox $name for $worktree_path"

  if [[ "$detach" == true ]]; then
    # Note: docker sandbox run does not support --detach natively.
    # Shell backgrounding is used as a workaround.
    "${cmd[@]}" &
    disown
    echo "Sandbox $name launched in background"
  else
    exec "${cmd[@]}"
  fi
}
cmd_attach() {
  require_docker_sandbox

  local branch

  if [[ $# -gt 0 ]]; then
    branch="$1"
  else
    require_git
    branch=$(branch_from_cwd)
  fi

  local name
  name=$(sandbox_name "$branch")

  sandbox_exists "$name" || die "no running sandbox named $name"

  echo "Attaching to sandbox $name"
  exec docker sandbox exec "$name" claude --dangerously-skip-permissions
}
cmd_ls() {
  require_docker_sandbox
  echo "Running Armature sandboxes:"
  docker sandbox ls 2>/dev/null | grep "${SANDBOX_PREFIX}-" || echo "  (none)"
}
cmd_stop() { die "not yet implemented"; }
cmd_rm() { die "not yet implemented"; }

# --- Main dispatcher ---

main() {
  case "${1:-}" in
    -h|--help) show_help; exit 0 ;;
    run)       shift; cmd_run "$@" ;;
    attach)    shift; cmd_attach "$@" ;;
    ls)        cmd_ls ;;
    stop)      shift; cmd_stop "$@" ;;
    rm)        shift; cmd_rm "$@" ;;
    "")        show_help; exit 0 ;;
    *)         cmd_run "$@" ;;  # default subcommand is run
  esac
}

main "$@"
